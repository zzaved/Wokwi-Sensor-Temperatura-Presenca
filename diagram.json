{
  "version": 1,
  "author": "Pablo Azevedo",
  "editor": "wokwi",
  "parts": [
    {
      "type": "board-pi-pico-w",
      "id": "pico",
      "top": 0,
      "left": 0,
      "attrs": {}
    },
    {
      "type": "wokwi-ntc-temperature-sensor",
      "id": "temp1",
      "top": -80,
      "left": 220,
      "attrs": { "temperature": "25" }
    },
    {
      "type": "wokwi-pushbutton",
      "id": "btn1",
      "top": 120,
      "left": 220,
      "attrs": { "color": "green", "label": "Presença" }
    },
    {
      "type": "wokwi-resistor",
      "id": "r1",
      "top": 150,
      "left": 180,
      "attrs": { "value": "10000" }
    }
  ],
  "connections": [
    ["pico:GP26", "temp1:OUT", "green", ["h10"]],
    ["pico:3V3", "temp1:VCC", "red", []],
    ["pico:GND.1", "temp1:GND", "black", []],
    ["pico:GP15", "btn1:1.l", "blue", ["h20"]],
    ["btn1:2.l", "pico:GND.2", "black", []],
    ["pico:3V3", "r1:1", "red", []],
    ["r1:2", "pico:GP15", "orange", []]
  ],
  "dependencies": {}
}
